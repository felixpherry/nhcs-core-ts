# Backend API base URL used by server functions.
API_BASE_URL="http://localhost:3001"

# Secret used to sign the app-owned nhcs_session cookie. Use at least 32 chars.
NHCS_SESSION_SECRET="change-me-to-at-least-32-characters"

# Legacy Cookies compatibility for older NHCS apps. Suffix must be non-empty.
COOKIE_SECRET="change-me-to-shared-legacy-cookie-secret"
COOKIE_NAME_SUFFIX="_LOCAL"
PARENT_DOMAIN_COOKIE="localhost"
APP_ENV="development"

# Public app title exposed to browser code.
VITE_APP_TITLE="NHCS Core"
